# Cole sua chave da OpenAI (obrigatório para o scan funcionar)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# Opcional — aumenta rate limit da Pokémon TCG API
# https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=

# Necessário para preços de Riftbound (TCGPlayer via tcgapi.dev)
# Plano gratuito: 100 req/dia — crie em: https://tcgapi.dev
TCGAPI_DEV_KEY=

# CORS — origens permitidas, separadas por vírgula
# Use * para permitir todas (padrão local). Em produção web, liste URLs explícitas:
# CORS_ORIGINS=https://meu-app.expo.dev,https://outro-dominio.com
CORS_ORIGINS=*

# Local apenas — Railway define PORT automaticamente; não configure no painel Railway
# PORT=8000
